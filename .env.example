# Copy this file to .env and put your own token from @BotFather in it.
# .env must never be committed (see .gitignore).

# --- Required ---
BOT_TOKEN=123456789:AAE-replace-with-your-token

# --- Resources ---
# Thread count for inference. Keep at or below the cores given to the container.
# The server has 4 cores and an idle TTS neighbour, so the bot takes all 4.
OMP_NUM_THREADS=4
NUM_THREADS=4

# --- Processing limits ---
# Reject uploads larger than this, in MB.
MAX_UPLOAD_MB=20
# Cap on the *decoded* pixel count. A file-size limit does not bound memory —
# a small compressed file can expand into an enormous array.
MAX_INPUT_PIXELS=50000000
# Cap on the input's long side, in px. Bounds peak memory.
MAX_INPUT_SIDE=2400
# Per-job timeout in seconds, so one pathological image cannot hold the worker forever.
JOB_TIMEOUT_SEC=300
# Maximum jobs waiting in the queue. Beyond this we decline politely.
MAX_QUEUE_SIZE=20
# Minimum delay between jobs from the same user, in seconds (anti-spam).
USER_COOLDOWN_SEC=5
